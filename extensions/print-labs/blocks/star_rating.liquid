<style>
  .custom-variant-block { max-width: 500px; margin: 20px 0; font-family: sans-serif; }
  .custom-variant-wrapper { margin-bottom: 15px; }
  .custom-variant-label { font-weight: bold; display: block; margin-bottom: 5px; font-size: 14px; }
  .custom-variant-select { width: 100%; padding: 10px; border-radius: 5px; border: 1px solid #ccc; background: #fff; }
  .file-upload-label { display: block; padding: 15px; border: 2px dashed #bbb; text-align: center; cursor: pointer; border-radius: 5px; background: #f9f9f9; }
  .custom-variant-button { width: 100%; padding: 12px; background: #000; color: #fff; border: none; border-radius: 5px; cursor: pointer; font-size: 16px; margin-top: 10px; }
</style>

<custom-calculator>
  <div class="custom-variant-block">
    {% assign product_custom_variants = product.metafields.custom.custom_variants.value %}

    <form id="customVariantForm">
      <input type="hidden" name="variantId" value="{{ product.selected_or_first_available_variant.id }}">
      
      {% for custom_variant in product_custom_variants %}
        <div class="custom-variant-wrapper">
          <label class="custom-variant-label">{{ custom_variant.variantTitle }}</label>
          <select class="custom-variant-select custom-calc-trigger" name="properties[{{ custom_variant.variantTitle }}]" data-operator="{{ custom_variant.operator | default: 'plus' }}">
            {% for option in custom_variant.options %}
              <option value="{{ option.value }}">{{ option.label }}</option>
            {% endfor %}
          </select>
        </div>
      {% endfor %}

      <div class="custom-variant-wrapper">
        <label class="custom-variant-label">Sets</label>
        <select class="custom-variant-select custom-calc-trigger" id="setsSelect" data-operator="into">
          {% for i in (1..50) %}<option value="{{ i }}">{{ i }}</option>{% endfor %}
        </select>
      </div>

      <div class="custom-variant-wrapper">
        <label class="file-upload-label" for="imageUpload">
          📁 <span id="fileNameDisplay">Upload Design</span>
        </label>
        <input type="file" id="imageUpload" style="display:none;" accept="image/*">
      </div>

      <div id="totalPriceDisplay" style="font-size: 22px; font-weight: bold; margin: 15px 0;">Total: 0.00</div>
      <button type="submit" class="custom-variant-button" id="submitBtn">Generate Invoice</button>
    </form>
  </div>
</custom-calculator>

<script>
  class CustomCalculator extends HTMLElement {
    connectedCallback() {
      this.form = this.querySelector('#customVariantForm');
      this.triggers = this.querySelectorAll('.custom-calc-trigger');
      this.display = this.querySelector('#totalPriceDisplay');
      this.fileInput = this.querySelector('#imageUpload');
      this.fileNameDisplay = this.querySelector('#fileNameDisplay');
      this.basePrice = parseFloat("{{ product.selected_or_first_available_variant.price | divided_by: 100.0 }}");
      
      // Event Listeners
      this.triggers.forEach(el => el.addEventListener('change', () => this.calculate()));
      this.form.addEventListener('submit', (e) => this.handleSubmit(e));
      
      // ফাইল নাম আপডেটের জন্য লিসেনার
      this.fileInput.addEventListener('change', () => {
        if(this.fileInput.files.length > 0) this.fileNameDisplay.textContent = this.fileInput.files[0].name;
      });

      this.calculate();
    }

    calculate() {
      let total = this.basePrice;
      this.triggers.forEach(el => {
        if (el.id !== 'setsSelect' && el.dataset.operator === 'plus') total += parseFloat(el.value || 0);
      });
      this.triggers.forEach(el => {
        if (el.dataset.operator === 'into') total *= parseFloat(el.value || 1);
      });
      this.display.innerText = "Total: " + total.toFixed(2);
      this.dataset.total = total.toFixed(2);
    }

    async handleSubmit(e) {
      e.preventDefault();
      const btn = this.querySelector('#submitBtn');
      btn.disabled = true;
      btn.innerText = "Processing...";

      const payload = {
        variantId: this.form.variantId.value,
        totalPrice: this.dataset.total || this.basePrice.toFixed(2),
        fileName: this.fileInput.files[0]?.name || "",
        imageData: this.fileInput.files[0] ? await this.getBase64(this.fileInput.files[0]) : null,
        properties: {}
      };

      this.triggers.forEach(el => {
        if(el.id !== 'setsSelect') {
          const label = el.name.replace("properties[", "").replace("]", "");
          payload.properties[label] = el.options[el.selectedIndex].text;
        }
      });

      const response = await fetch('/apps/customprice/api/customprice', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      
      const result = await response.json();
      if (result.url) window.location.href = result.url;
      else { alert(result.error); btn.disabled = false; btn.innerText = "Generate Invoice"; }
    }

    getBase64(file) {
      return new Promise(resolve => {
        const reader = new FileReader();
        reader.onloadend = () => resolve(reader.result);
        reader.readAsDataURL(file);
      });
    }
  }
  customElements.define('custom-calculator', CustomCalculator);
</script>

{% schema %}
{
  "name": "Product Variant Block",
  "target": "section",
  "settings": []
}
{% endschema %}
